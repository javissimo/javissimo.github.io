{
  "name": "notiz",
  "version": "0.2.0",
  "contributors": [{
      "name": "Gary Großgarten",
      "url": "https://notiz.dev/authors/gary-grossgarten"
    },
    {
      "name": "Marc Stammerjohann",
      "url": "https://notiz.dev/authors/marc-stammerjohann"
    }
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:Azure": "npm run build:scully",
    "build:prod": "ng build --prod --output-hashing none",
    "test": "ng test",
    "dev": "npm run build && npm run scully && npm run scully:serve",
    "build:scully": "npm run build:prod && npm run scully",
    "build:design": "ng build --project design --prod",
    "fix": "eslint . --ext .ts --quiet --fix",
    "lint": "eslint . --ext .ts",
    "e2e": "ng e2e",
    "format": "prettier --write \"src/**/*{.ts,.scss}\"",
    "scully": "scully",
    "serve:scully": "scully serve",
    "scully:ci": "npm run scully -- --host='0.0.0.0' --scanRoutes --serverTimeout=60000 && sh 404.sh",
    "optimize:images": "node optimize-images.js",
    "link:add": "node projects/link-generator && ng build && npm run scully",
    "publish:ngx-design": "npm run build:design && npm publish dist/design --tag alpha"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "10.1.1",
    "@angular/common": "10.1.1",
    "@angular/compiler": "10.1.1",
    "@angular/core": "10.1.1",
    "@angular/elements": "10.1.1",
    "@angular/forms": "10.1.1",
    "@angular/platform-browser": "10.1.1",
    "@angular/platform-browser-dynamic": "10.1.1",
    "@angular/router": "10.1.1",
    "@angular/service-worker": "10.1.1",
    "@scullyio/init": "1.0.0",
    "@scullyio/ng-lib": "1.0.0-beta.1",
    "@scullyio/scully": "1.0.0-beta.6",
    "document-register-element": "1.14.6",
    "ngx-markdown": "10.1.1",
    "prismjs": "1.21.0",
    "rxjs": "6.6.3",
    "tslib": "2.0.1",
    "zone.js": "0.11.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.1001.1",
    "@angular-devkit/build-angular": "0.1001.1",
    "@angular-devkit/build-ng-packagr": "0.1001.1",
    "@angular-eslint/eslint-plugin": "^0.3.0-beta.1",
    "@angular/cli": "10.1.1",
    "@angular/compiler-cli": "10.1.1",
    "@angular/language-service": "10.1.1",
    "@gammastream/scully-plugin-sitemap": "1.0.4",
    "@notiz/scully-plugin-copy-static-content": "file:projects/copy-static-content",
    "@notiz/scully-plugin-fouc": "0.2.0",
    "@notiz/scully-plugin-lazy-images": "0.3.0",
    "@notiz/scully-plugin-medium-zoom": "0.2.4",
    "@notiz/scully-plugin-rss": "0.3.0",
    "@types/jasmine": "3.5.14",
    "@types/jasminewd2": "2.0.8",
    "@types/node": "14.10.1",
    "@typescript-eslint/eslint-plugin": "^4.1.0",
    "@typescript-eslint/parser": "^4.1.0",
    "codelyzer": "6.0.0",
    "eslint": "7.7.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prefer-arrow": "^1.2.2",
    "eslint-plugin-promise": "^4.2.1",
    "fast-xml-parser": "~3.17.4",
    "imagemin": "7.0.1",
    "imagemin-jpegtran": "7.0.0",
    "imagemin-pngquant": "9.0.1",
    "imagemin-svgo": "8.0.0",
    "jasmine-core": "3.6.0",
    "jasmine-spec-reporter": "5.0.2",
    "karma": "5.2.2",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.5.4",
    "ng-packagr": "^10.0.4",
    "ngx-build-plus": "10.1.1",
    "postcss-import": "12.0.1",
    "postcss-loader": "3.0.0",
    "postcss-scss": "2.1.1",
    "prettier": "2.1.1",
    "protractor": "7.0.0",
    "stylelint-config-recommended": "^3.0.0",
    "tailwindcss": "1.8.8",
    "ts-node": "9.0.0",
    "typescript": "3.9.6"
  }
