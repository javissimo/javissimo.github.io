{
  "name": "notiz",
  "version": "0.2.0",
  "contributors": [
    {
      "name": "Gary Großgarten",
      "url": "https://notiz.dev/authors/gary-grossgarten"
    },
    {
      "name": "Marc Stammerjohann",
      "url": "https://notiz.dev/authors/marc-stammerjohann"
    }
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production --output-hashing none",
    "test": "ng test",
    "dev": "npm run build && npm run serve:scully",
    "build:scully": "npm run build:prod && npm run scully",
    "build:design": "ng build --project design --configuration production",
    "build:shortcodes": "ng build --configuration production --project shortcodes --single-bundle --output-hashing none",
    "fix": "eslint . --ext .ts --quiet --fix",
    "lint": "eslint . --ext .ts",
    "e2e": "ng e2e",
    "format": "prettier --write \"src/**/*.{ts,scss}\"",
    "scully": "scully",
    "serve:scully": "scully serve",
    "scully:ci": "npm run scully -- --host='0.0.0.0' --scanRoutes --serverTimeout=60000",
    "blick:serve": "blick open http://localhost:4200 & ng s",
    "optimize:images": "node optimize-images.js",
    "link:add": "node projects/link-generator && ng build && npm run scully",
    "publish:ngx-design": "npm run build:design && npm publish dist/design --tag alpha"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "12.0.5",
    "@angular/common": "12.0.5",
    "@angular/compiler": "12.0.5",
    "@angular/core": "12.0.5",
    "@angular/elements": "12.0.5",
    "@angular/forms": "12.0.5",
    "@angular/platform-browser": "12.0.5",
    "@angular/platform-browser-dynamic": "12.0.5",
    "@angular/router": "12.0.5",
    "@angular/service-worker": "12.0.5",
    "@scullyio/init": "1.1.4",
    "@scullyio/ng-lib": "1.1.1",
    "@scullyio/scully": "1.1.1",
    "document-register-element": "1.14.10",
    "ngx-markdown": "12.0.1",
    "prismjs": "1.22.0",
    "rxjs": "6.6.6",
    "tslib": "2.3.0",
    "zone.js": "0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.1202.3",
    "@angular-devkit/build-angular": "12.2.3",
    "@angular-eslint/eslint-plugin": "12.1.0",
    "@angular/cli": "12.2.3",
    "@angular/compiler-cli": "12.0.5",
    "@angular/language-service": "12.0.5",
    "@gammastream/scully-plugin-sitemap": "1.0.7",
    "@notiz/scully-plugin-copy-static-content": "file:projects/copy-static-content",
    "@notiz/scully-plugin-fouc": "0.2.0",
    "@notiz/scully-plugin-lazy-images": "0.4.1",
    "@notiz/scully-plugin-medium-zoom": "0.2.4",
    "@notiz/scully-plugin-rss": "1.1.0",
    "@tailwindcss/typography": "0.4.1",
    "@types/jasmine": "3.7.7",
    "@types/jasminewd2": "2.0.9",
    "@types/node": "15.12.4",
    "@typescript-eslint/eslint-plugin": "^4.27.0",
    "eslint": "7.22.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-promise": "4.3.1",
    "fast-xml-parser": "3.19.0",
    "imagemin": "8.0.0",
    "imagemin-jpegtran": "7.0.0",
    "imagemin-pngquant": "9.0.2",
    "imagemin-svgo": "9.0.0",
    "jasmine-core": "3.7.1",
    "jasmine-spec-reporter": "4.2.1",
    "karma": "6.3.4",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "4.0.1",
    "karma-jasmine-html-reporter": "1.6.0",
    "ng-packagr": "12.0.6",
    "ngx-build-plus": "^12.0.1",
    "prettier": "2.3.1",
    "stylelint-config-recommended": "5.0.0",
    "tailwindcss": "2.0.4",
    "ts-node": "8.3.0",
    "typescript": "4.2.3",
    "xmlbuilder": "^13.0.2"
  }
}